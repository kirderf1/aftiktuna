{
  "type": "object",
  "patternProperties": {
    "^[a-z_0-9]+$": {
      "type": "object",
      "allOf": [
        {
          "title": "General background data",
          "oneOf": [
            {
              "properties": {
                "texture": { "$ref": "./parts/name_path.json" },
                "move_factor": { "type": "number" },
                "is_looping": { "type": "boolean" },
                "offset": { "$ref": "./parts/background_layer_offset.json" }
              },
              "required": [ "texture" ]
            },
            {
              "properties": {
                "layers": {
                  "type": "array",
                  "items": { "$ref": "./parts/background_layer.json"}
                }
              },
              "required": [ "layers" ]
            }
          ]
        },
        {
          "title": "Portrait background data",
          "oneOf": [
            {
              "properties": {
                "portrait_color": { "$ref": "./parts/array_color.json" }
              },
              "required": [ "portrait_color" ]
            },
            {
              "properties": {
                "portrait_texture": { "$ref": "./parts/name_path.json" }
              },
              "required": [ "portrait_texture" ]
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "additionalProperties": false
}
